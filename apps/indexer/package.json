{
  "name": "@wirefluid/indexer",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "XDG_CONFIG_HOME=.ponder-config ponder dev",
    "start": "XDG_CONFIG_HOME=.ponder-config ponder start",
    "serve": "XDG_CONFIG_HOME=.ponder-config ponder serve",
    "build": "XDG_CONFIG_HOME=.ponder-config ponder codegen",
    "lint": "XDG_CONFIG_HOME=.ponder-config ponder codegen && tsc -p tsconfig.json",
    "typecheck": "XDG_CONFIG_HOME=.ponder-config ponder codegen && tsc -p tsconfig.json"
  },
  "dependencies": {
    "@wirefluid/contracts": "workspace:*",
    "hono": "^4.7.11",
    "ponder": "^0.12.16",
    "viem": "^2.31.0"
  },
  "devDependencies": {
    "typescript": "^5.8.3"
  }
}
