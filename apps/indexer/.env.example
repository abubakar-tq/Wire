# Local Anvil defaults. For WireFluid Testnet use chain 92533 and https://evm.wirefluid.com.
WIREFLUID_CHAIN_ID=31337
WIREFLUID_RPC_URL=http://127.0.0.1:8545
DATABASE_URL=postgres://postgres:postgres@localhost:5432/wirefluid_indexer
# Required by Ponder when using Postgres/Neon. Use a dedicated schema when sharing the DB with the web app.
DATABASE_SCHEMA=ponder
PONDER_START_BLOCK=0

# Optional contract address overrides. By default the indexer reads packages/contracts/deployments/<chainId>.json.
MATCH_REGISTRY=
FANTASY_TEAM_NFT=
LEGACY_PASSPORT=
SCORE_MANAGER=
CONTEST_MANAGER=
