# Local Anvil defaults. For WireFluid Testnet use chain 92533 and https://evm.wirefluid.com.
WIREFLUID_CHAIN_ID=31337
WIREFLUID_RPC_URL=http://127.0.0.1:8545
NEXT_PUBLIC_WIREFLUID_CHAIN_ID=31337
NEXT_PUBLIC_WIREFLUID_RPC_URL=http://127.0.0.1:8545

# Optional contract address overrides. By default apps read packages/contracts/deployments/<chainId>.json.
MATCH_REGISTRY=
FANTASY_TEAM_NFT=
LEGACY_PASSPORT=
SCORE_MANAGER=
CONTEST_MANAGER=
NEXT_PUBLIC_MATCH_REGISTRY=
NEXT_PUBLIC_FANTASY_TEAM_NFT=
NEXT_PUBLIC_LEGACY_PASSPORT=
NEXT_PUBLIC_SCORE_MANAGER=
NEXT_PUBLIC_CONTEST_MANAGER=

# Frontend public config
NEXT_PUBLIC_INDEXER_URL=http://localhost:42069
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# Admin auth
AUTH_SESSION_SECRET=replace-with-at-least-32-random-bytes

# Ponder indexer
DATABASE_URL=postgres://postgres:postgres@localhost:5432/wirefluid_indexer
PONDER_START_BLOCK=0
